APP_ENV=local

# Leave MYSQL_DSN empty to build it from the fields below.
# For AWS RDS, set MYSQL_HOST to the RDS endpoint, for example:
# MYSQL_HOST=mydb.xxxxx.ap-southeast-1.rds.amazonaws.com
MYSQL_DSN=
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=training
MYSQL_PASSWORD=training
MYSQL_DATABASE=training_msg_queue
MYSQL_TLS=

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

AWS_REGION=ap-southeast-1
AWS_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

SQS_QUEUE_URL=http://localstack:4566/000000000000/message-events
SQS_DLQ_URL=http://localstack:4566/000000000000/message-events-dlq
S3_BUCKET=training-user-segments
DYNAMODB_TABLE=message_process_logs

MAX_RETRY=3
POLL_WAIT_SECONDS=10
SUBSCRIBER_WORKERS=4
PUBLISHER_POLL_SECONDS=5
PUBLISHER_WORKERS=4
PUBLISHER_CLAIM_LIMIT=10
LINE_ENDPOINT=http://line-mock:8080/messages
LINE_CHANNEL_TOKEN=local-token
